# ─────────────────────────────────────────────────────────────────────────────
# ContentFactory — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# ADAPTER_MODE=fixture  → runs fully without any external API keys (default)
# ADAPTER_MODE=live     → requires ANTHROPIC_API_KEY and DEEPL_API_KEY
# ─────────────────────────────────────────────────────────────────────────────

# Adapter mode — use 'fixture' for portfolio demo, 'live' for real API calls
ADAPTER_MODE=fixture

# ─── Supabase (required even in fixture mode — app reads/writes to DB) ───────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Inngest (required for job orchestration) ────────────────────────────────
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ─── Live mode only — leave blank for fixture mode ───────────────────────────

# Anthropic API (used directly or auto-detected by the AI SDK provider)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# DeepL Translation API
# Get key: https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Shopify Admin API (for live push)
# Create private app: Shopify Admin → Settings → Apps → Develop apps
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# WordPress REST API + WPML (for live push)
# Generate Application Password: WP Admin → Users → Profile → Application Passwords
WP_SITE_URL=
WP_USERNAME=
WP_APP_PASSWORD=
